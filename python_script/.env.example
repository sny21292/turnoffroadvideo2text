# Copy to .env and fill in secrets. Never commit .env.

# ══════════════════════════════════════════════════════════════════
# REQUIRED — API keys (startup fails without these)
# ══════════════════════════════════════════════════════════════════
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=

# ══════════════════════════════════════════════════════════════════
# HTTP API (api_server.py) — production
# ══════════════════════════════════════════════════════════════════
API_KEY=
API_JOBS_DIR=api_jobs
API_MAX_CONCURRENT_JOBS=1

# After each successful job: archive job.json → api_jobs/_archive/, delete api_jobs/<id>/
API_DELETE_JOB_DIR_ON_SUCCESS=true
API_DELETE_JOB_DIR_ON_FAILURE=false

# Legacy workspace-only cleanup (used only if DELETE_JOB_DIR is false)
API_CLEANUP_WORKSPACE_ON_SUCCESS=true
API_CLEANUP_WORKSPACE_ON_FAILURE=false

# Purge stale job dirs + archived job.json on server start (0 = off)
API_PRUNE_OLD_JOBS_DAYS=7

# ══════════════════════════════════════════════════════════════════
# Deliverables — Sunil dashboard reads files from here
# ══════════════════════════════════════════════════════════════════
DELIVERABLE_OUTPUT_DIR=output
# Production droplet (Sunil):
# DELIVERABLE_OUTPUT_DIR=/var/data/videototext/output
DELIVERABLE_FILENAME_STYLE=video_id
LOGO_PATH=assets/turnoffroad_logo1.jpg

# ══════════════════════════════════════════════════════════════════
# Models
# ══════════════════════════════════════════════════════════════════
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MAX_TOKENS=16000
CLAUDE_TEMPERATURE=0

OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o
OPENAI_ENABLE_MODEL_FALLBACK=true
OPENAI_RETRIES_BEFORE_FALLBACK=2
OPENAI_TRANSCRIBE_FALLBACK_MODELS=gpt-4o-mini-transcribe
OPENAI_VISION_FALLBACK_MODELS=gpt-4o-mini

GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_ENABLE_MODEL_FALLBACK=true
GEMINI_RETRIES_BEFORE_FALLBACK=2
GEMINI_TRANSCRIBE_FALLBACK_MODELS=gemini-2.0-flash
GEMINI_VISION_FALLBACK_MODELS=gemini-2.0-flash

# ══════════════════════════════════════════════════════════════════
# YouTube download auth (required on DigitalOcean / datacenter IPs)
# Sunil droplet: cookies already at /etc/yt-dlp/cookies.txt
# See DEPLOY.md for export + refresh steps.
# ══════════════════════════════════════════════════════════════════
# Local dev: leave empty (home IP usually works)
# Production:
YT_DLP_COOKIES_FILE=/etc/yt-dlp/cookies.txt
YT_DLP_REMOTE_COMPONENTS=ejs:github
YT_DLP_PLAYER_CLIENT=web,mweb,android
YT_DLP_BIN=/var/www/Video2Text/python_script/.venv/bin/yt-dlp
# Optional residential proxy if cookies alone fail:
# YT_DLP_PROXY=http://user:pass@residential-proxy-host:port

# ══════════════════════════════════════════════════════════════════
# Pipeline tuning (defaults match production-tested .env)
# ══════════════════════════════════════════════════════════════════
YT_DLP_PREFER_720_FIRST=true

SCENE_THRESHOLD=0.35
SCENE_DETECTION_TIMEOUT_SECONDS=120

MIN_STEP_GAP_SECONDS=10
VIDEO_OUTRO_EXCLUSION_SECONDS=20
MAX_TRANSCRIPT_WINDOW_SECONDS=35
OUTRO_STEP_LOOKBACK_SECONDS=90

VISUAL_PRE_ROLL=1.0
VISUAL_POST_ROLL=6.0
VISUAL_SAMPLE_INTERVAL=0.3
MAX_CANDIDATE_FRAMES=24
UNIFORM_SAMPLE_RESERVED_SLOTS=6
SCREENSHOT_CONCURRENCY=2

SHARPNESS_MIN=80.0
BRIGHTNESS_MIN=30.0
BRIGHTNESS_MAX=230.0
MIN_FRAMES_AFTER_QUALITY_FILTER=6

VISION_MIN_CONFIDENCE=0.70
VISION_RETRY_MIN_CONFIDENCE=0.50
PARTIAL_MATCH_MIN_CONFIDENCE=0.40
ALLOW_PARTIAL_VISUAL_MATCH=true
ENABLE_VISION_CONFIRMATION=true
VISION_CONFIRM_FLOOR=0.48
VISION_CONFIRM_THRESHOLD=0.75

ENABLE_LOW_CONFIDENCE_REFINE=true
LOW_CONFIDENCE_REFINE_THRESHOLD=0.75
LOW_CONFIDENCE_REFINE_FRAMES=28
LOW_CONFIDENCE_REFINE_MIN_GAIN=0.05

OPENAI_VISION_TIMEOUT_SEC=180
OPENAI_VISION_MAX_RETRIES=7
OPENAI_VISION_BASE_DELAY=8.0
OPENAI_VISION_IMAGE_DETAIL=auto

WIDE_RESCUE_PRE_ROLL=35.0
WIDE_RESCUE_POST_ROLL=45.0
WIDE_RESCUE_FRAMES=16
MULTI_PERSON_RESCUE_CONFIDENCE=0.80
WHOLE_VIDEO_RESCUE_ENABLED=true
WHOLE_VIDEO_RESCUE_FRAMES=24
WHOLE_VIDEO_RESCUE_MIN_CONFIDENCE=0.65

ALWAYS_FILL_SCREENSHOTS=true
FINAL_FALLBACK_STRATEGY=midpoint
DOC_INCLUDE_LOW_CONFIDENCE_SCREENSHOTS=true
CLIENT_DEMO_MODE=true

# Word layout (white client template)
DOC_DARK_THEME=false
DOC_ACCENT_COLOR=E8634B
LOGO_WIDTH_INCHES=2.75
DOC_HEADER_LOGO_MAX_WIDTH_INCHES=2.75
DOC_HEADER_LOGO_MAX_HEIGHT_INCHES=0.72
DOC_CONTENT_WIDTH_INCHES=6.5
DOC_LEFT_MARGIN_INCHES=0.75
DOC_RIGHT_MARGIN_INCHES=0.75
DOC_STEP_TEXT_WIDTH_INCHES=2.92
DOC_STEP_IMAGE_WIDTH_INCHES=3.58
# Show per-step video timestamp + clickable YouTube link (client review workflow)
DOC_SHOW_STEP_TIMESTAMPS=true

DEBIAS_TIMESTAMPS=true
SAFE_END_PADDING_SECONDS=2.0
H264_PROCESSING_WIDTH=1280
FRAME_EXTRACT_WIDTH=1280
FINAL_SCREENSHOT_WIDTH=1920
FRAME_FINAL_ACCURATE_SEEK=true
FRAME_FINAL_PRE_SEEK_SECONDS=2.0
FFMPEG_FINAL_SCREENSHOT_TIMEOUT_SEC=120
FFMPEG_CANDIDATE_FRAME_TIMEOUT_SEC=75
