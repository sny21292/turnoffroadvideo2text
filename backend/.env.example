PORT=8000
JWT_SECRET=change-me-to-a-long-random-string
# Absolute path to the python script provided by the client.
# It must accept the YouTube URL as the first argument and write
# the resulting PDF to the path given as the second argument.
PYTHON_SCRIPT=/absolute/path/to/your/script.py
# Python executable (python3 by default)
PYTHON_BIN=python3
# Directory where generated PDFs are stored
OUTPUT_DIR=./output
# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:3000
